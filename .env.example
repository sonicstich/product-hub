# Notion integration token — server-side only, NEVER commit the real value.
# Create an internal integration at https://www.notion.so/my-integrations
# then share the Tasks database with it, and paste its secret here.
#
# Local dev: copy this file to `.env` and fill in the value.
# Vercel: set NOTION_TOKEN in Project Settings → Environment Variables.
#
# NOTE: NOTION_TOKEN is the classic workspace-scoped "Access token". If you
# can't create one (often admin-restricted), use the OAuth flow below instead
# — you don't need NOTION_TOKEN then.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion via OAuth (alternative to NOTION_TOKEN) ────────────────────
# Create an OAuth connection at https://www.notion.so/profile/integrations
# (Authentication method: OAuth). Set the Redirect URI to
# https://<your-domain>/api/notion-callback, then paste the connection's
# Client ID + Client secret here. After deploying, visit /api/notion-connect
# once to authorize — tokens are stored in Supabase and auto-refreshed.
NOTION_OAUTH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_OAUTH_CLIENT_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database id for the "Share user feedback" form. Create a database
# with properties: Title (title), Description (text), Users affected (number),
# Importance (select: Low/Medium/High), User ID (text); add the Product Hub
# connection to it; then paste its id here.
NOTION_FEEDBACK_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Incidents storage (Supabase Postgres) ────────────────────────────
# From your Supabase project → Settings → API.
# Without these the app still runs, but incidents live in memory only
# (per-instance, not shared, reset on restart/redeploy). Set them for
# shared, permanent persistence. Use the service_role key (server-side
# only, never exposed to the browser) — NOT the anon/public key.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Slack incident notifications (optional) ──────────────────────────
# Create a Slack app (https://api.slack.com/apps), add the bot scope
# `chat:write`, install it, invite the bot to your channel. Then set the
# bot token + channel id below. When set, each new incident is posted to
# the channel (title + description + severity), and status changes reply in
# that thread. Requires the migration:
#   alter table incidents add column if not exists slack_ts text;
#   alter table incidents add column if not exists slack_channel text;
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0XXXXXXXXX
# Optional — used in the Slack message link back to the app:
# APP_BASE_URL=https://product-hub-cusp.vercel.app
